# CONFIGURATION FOR TITANES F.C. BACKEND

# Server Port
PORT=3000

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=titanes_fc_db

# JWT Configuration
JWT_SECRET=supersecret_titanes_cambiar_en_produccion
JWT_EXPIRES_IN=2h

# Refresh Token Configuration
REFRESH_TOKEN_SECRET=supersecret_refresh_cambiar_en_produccion
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Environment (development or production)
NODE_ENV=development

# Optional: API Documentation
API_DOCS_ENABLED=true
